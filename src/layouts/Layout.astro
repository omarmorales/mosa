---
const { title } = Astro.props;
import 'nes.css/css/nes.min.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Preconnect to Google Fonts to speed up font delivery -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    
    <style is:global>
      body {
        font-family: 'Press Start 2P', cursive;
        background-color: #212529;
        color: #fff;
        margin: 0;
        padding: 0;
      }
      .nes-container.is-dark {
        background-color: #212529;
        color: #fff;
      }
      .container {
        max-width: 980px;
        margin: 0 auto;
        padding: 20px;
      }
      a { color: #fff; text-decoration: none; }
      a:hover { color: #209cee; }
      header {
        margin-bottom: 40px;
        text-align: center;
        border-bottom: 4px solid #fff;
        padding-bottom: 20px;
      }
      h1 { color: #209cee; font-size: 2rem; margin-bottom: 10px; word-wrap: break-word; }
      header h1 {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
      }
      header h1 .nes-icon.star {
        width: 64px;
        height: 64px;
        margin: 0 !important;
      }
      h2, h3 { color: #fbed64; }
      .nes-btn { font-family: 'Press Start 2P', cursive; }
      
      /* Progress bar tweaks for dark theme */
      .nes-progress { height: 30px; }

      /* Retro Preloader Overlay */
      .retro-loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: #212529;
        z-index: 9999;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 1;
        transition: opacity 0.4s ease-in-out, visibility 0.4s;
        visibility: visible;
      }
      
      .retro-loader.fade-out {
        opacity: 0;
        visibility: hidden;
      }
      
      .loader-content {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
      }
      
      .loader-text {
        font-family: 'Press Start 2P', monospace;
        color: #fbed64;
        font-size: 0.8rem;
        margin: 0;
        letter-spacing: 2px;
        animation: blink 1s step-end infinite;
      }
      
      @keyframes blink {
        50% { opacity: 0; }
      }

      /* Blinking Retro Typewriter Cursor */
      .retro-cursor {
        display: inline-block;
        width: 8px;
        height: 15px;
        background-color: currentColor;
        margin-left: 4px;
        animation: cursor-blink 0.8s step-end infinite;
        vertical-align: middle;
      }
      @keyframes cursor-blink {
        50% { background-color: transparent; }
      }

      /* Stepped interactive hover transitions for cards */
      .nes-container.is-dark.is-rounded {
        transition: transform 0.1s steps(2);
      }
      .nes-container.is-dark.is-rounded:hover {
        transform: translateY(-4px);
      }

      /* Bobbing stepped animation for collectibles' SVGs on card hover */
      .nes-container.is-dark.is-rounded:hover svg {
        animation: collectible-bob 0.6s steps(4) infinite alternate;
      }
      @keyframes collectible-bob {
        0% {
          transform: translateY(0) rotate(0deg);
        }
        100% {
          transform: translateY(-3px) rotate(8deg);
        }
      }

      /* Mobile First / Responsive Adjustments */
      @media (max-width: 768px) {
        body { font-size: 12px; }
        h1 { font-size: 1.2rem; }
        .container { padding: 10px; }
        .nes-container { padding: 1rem; }
        /* Make sure tables or flex containers don't break the viewport */
        .nes-table-responsive { margin: 0 -1rem; padding: 0 1rem; }
        .title { font-size: 14px; }

        /* Hide header star icons on mobile to keep it clean */
        header h1 .nes-icon.star {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <!-- Retro Loader Screen -->
    <div id="loader" class="retro-loader">
      <div class="loader-content">
        <i class="nes-icon star is-large is-spinning"></i>
        <p class="loader-text">BOOTING SYSTEM...</p>
        <div class="nes-progress is-primary" style="width: 250px;">
          <div class="bar" id="loader-bar" style="width: 0%;"></div>
        </div>
      </div>
    </div>

    <div class="container">
      <header>
        <h1><i class="nes-icon is-large star"></i> Developer Player 1 <i class="nes-icon is-large star"></i></h1>
        <p>Omar Morales - Full Stack Engineer</p>
      </header>
      <slot />
    </div>

    <script is:inline>
      // Fast fake progress bar for retro booting feel
      const bar = document.getElementById('loader-bar');
      let progress = 0;
      const interval = setInterval(() => {
        if (progress < 90) {
          progress += Math.floor(Math.random() * 15) + 5;
          if (progress > 90) progress = 90;
          if (bar) bar.style.width = progress + '%';
        }
      }, 70);

      window.addEventListener('load', () => {
        // Set progress to 100%
        clearInterval(interval);
        if (bar) bar.style.width = '100%';
        
        // Hide loader after a tiny delay for visual polish
        setTimeout(() => {
          const loader = document.getElementById('loader');
          if (loader) {
            loader.classList.add('fade-out');
          }
        }, 200);
      });
    </script>
  </body>
</html>

