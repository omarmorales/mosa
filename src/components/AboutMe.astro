---
---
<section style="margin-bottom: 40px; margin-top: 20px;">
  <div class="dialogue-container" style="display: flex; gap: 15px; align-items: flex-end;">
    
    <!-- Character Sprite -->
    <div class="avatar-container" style="text-align: center; flex-shrink: 0;">
      <img 
        src="/profile.png" 
        alt="Player 1 Avatar" 
        width="100" 
        height="100" 
        fetchpriority="high"
        style="width: 100px; height: 100px; image-rendering: pixelated;" 
      />
    </div>

    <!-- Speech Balloon (Dialogue Box) -->
    <div class="nes-balloon from-left is-dark dialogue-balloon" style="flex: 1; min-width: 0;">
      <p>Hello! I'm Omar.</p>
      <p style="margin-top: 10px;">I love building robust, performant web applications and automating my life.</p>
      <p style="margin-top: 15px; color: #92cc41;">Skills: Python, React, Astro, Postgres</p>
    </div>

  </div>
</section>

<style>
  /* Ensure the dialogue box stays side-by-side with the image on tiny screens */
  @media (max-width: 600px) {
    .dialogue-container {
      gap: 10px !important;
    }
    .avatar-container img {
      width: 70px !important; /* shrink avatar slightly */
    }
    .dialogue-balloon {
      padding: 1rem !important;
    }
    .dialogue-balloon p {
      font-size: 0.65rem !important;
    }
  }
</style>
